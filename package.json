{
  "name": "@travvy/anpan",
  "version": "0.1.4",
  "description": "A lightweight Bun-native SSR framework with TSX templating and islands architecture",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trvswgnr/anpan.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./islands": {
      "browser": "./src/islands/browser-stub.ts",
      "default": "./src/islands/index.ts"
    },
    "./jsx-runtime": "./src/jsx/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx/jsx-dev-runtime.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "example": "./scripts/run-example.sh $1",
    "build": "bun run src/build/index.ts",
    "test": "bun test",
    "typecheck": "./scripts/typecheck.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "1.56.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

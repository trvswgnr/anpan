{
  "name": "@travvy/anpan",
  "version": "0.1.1",
  "description": "A lightweight Bun-native SSR framework with TSX templating and islands architecture",
  "type": "module",
  "main": "./src/index.ts",
  "files": ["src"],
  "exports": {
    ".": "./src/index.ts",
    "./islands": {
      "browser": "./src/islands/browser-stub.ts",
      "default": "./src/islands/index.ts"
    },
    "./jsx-runtime": "./src/jsx/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx/jsx-dev-runtime.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "cd examples/dev && bun run --hot main.ts",
    "example:blog": "cd examples/blog && bun run --hot main.ts",
    "example:react": "cd examples/react && bun run --hot main.ts",
    "example:preact": "cd examples/preact && bun run --hot main.ts",
    "example:solidjs": "cd examples/solidjs && bun run --hot main.ts",
    "build": "bun run src/build/index.ts",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "1.56.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

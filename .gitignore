node_modules/
# Track the manually-maintained anpan stub packages for examples that cannot
# use bun install (circular local file-path dependency prevention).
# Pattern: un-ignore the node_modules dir, re-ignore everything inside it,
# then un-ignore only the anpan/ stub and its contents.
!examples/blog/node_modules/
examples/blog/node_modules/*
!examples/blog/node_modules/anpan/
!examples/blog/node_modules/anpan/**
!examples/solidjs/node_modules/
examples/solidjs/node_modules/*
!examples/solidjs/node_modules/anpan/
!examples/solidjs/node_modules/anpan/**
.anpan/
dist/
*.js.map
.DS_Store
